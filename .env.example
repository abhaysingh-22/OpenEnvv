# OpenEnv Environment Configuration
# Copy this file to .env and fill in your actual values.

# Required for LLM-based agent (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: custom API endpoint (leave empty for official OpenAI)
API_BASE_URL=

# Optional: Hugging Face token (for HF Spaces deployment)
HF_TOKEN=your_huggingface_token_here

# Model to use
MODEL_NAME=gpt-4.1-mini

# Runtime settings
DEVICE=cpu
MAX_STEPS=100
TIMEOUT=300
LOG_LEVEL=INFO