# OpenAI API key for LLM agent (Phase 2). Omit for scripted fallback.
OPENAI_API_KEY=your_openai_api_key_here

# Custom API endpoint (optional, for proxies or alternative providers)
API_BASE_URL=

# Hugging Face token for Space deployment (optional)
HF_TOKEN=your_huggingface_token_here

# Model to use with the OpenAI client (default: gpt-4.1-mini)
MODEL_NAME=gpt-4.1-mini