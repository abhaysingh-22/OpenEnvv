# Environment variables for OpenEnv
# Copy this to .env and fill in your actual values

# OpenAI Configuration (REQUIRED for baseline.py with gpt-4o-mini)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base URL (OPTIONAL)
# Leave empty to use official OpenAI API
# Use this for custom endpoints or proxies
API_BASE_URL=

# Hugging Face Configuration (REQUIRED for Hugging Face Spaces deployment)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Model settings
MODEL_NAME=gpt-4o-mini
DEVICE=cpu

# Environment settings
MAX_STEPS=100
TIMEOUT=300

# Logging
LOG_LEVEL=INFO