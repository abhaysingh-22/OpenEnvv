# API key for LLM agent (Phase 2). Omit for scripted fallback.
# Can be OpenAI key, Hugging Face token, or any compatible API key
HF_TOKEN=your_api_key_here

# Custom API endpoint (optional, for proxies or alternative providers)
API_BASE_URL=https://api.openai.com/v1

# Model to use with the OpenAI client (default: gpt-4.1-mini)
MODEL_NAME=gpt-4.1-mini
